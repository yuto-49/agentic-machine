# Claude API — Required
ANTHROPIC_API_KEY=1111

# OpenClaw webhook authentication — Required
WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# Slack (required for OpenClaw Slack integration)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Discord (required for OpenClaw Discord integration)
DISCORD_BOT_TOKEN=your-discord-bot-token

# Database (default: SQLite in project root)
DATABASE_URL=sqlite+aiosqlite:///./claudius.db

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=DEBUG
