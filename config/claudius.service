[Unit]
Description=Claudius AI Vending Machine (FastAPI + Agent)
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/claudius-vend
EnvironmentFile=/home/pi/claudius-vend/.env
ExecStart=/home/pi/claudius-vend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
