[Unit]
Description=OpenClaw Gateway (Slack/Discord message router)
After=network.target claudius.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/.openclaw
ExecStart=/usr/local/bin/openclaw gateway start
Restart=always
RestartSec=10
Environment="NODE_ENV=production"

[Install]
WantedBy=multi-user.target
